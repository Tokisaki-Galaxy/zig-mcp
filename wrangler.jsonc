{
    "name": "zig-mcp-worker",
    "main": "worker/index.ts",
    "compatibility_date": "2026-04-23",
    "compatibility_flags": ["nodejs_compat"],
    "observability": {
        "logs": {
            "enabled": true,
            "invocation_logs": true
        }
    },
    "vars": {
        "DEFAULT_ZIG_VERSION": "master"
    },
    "r2_buckets": [
        {
            "binding": "ZIG_DOCS",
            "bucket_name": "zig-docs"
        }
    ],
    "placement": { "mode": "smart" }
}
